import numpy as np
from config_connector import LOOKBACK, THRESHOLD, WICK_RATIO_THRESHOLD, EXTREME_WICK_RATIO, MIN_BODY
from config_connector import MOMENTUM_LOOKBACK, MOMENTUM_THRESHOLD_1, MOMENTUM_THRESHOLD_2, MOMENTUM_THRESHOLD_EXTREME
from config_connector import STRONG_CLOSE_RATIO, CONSECUTIVE_COUNT, VOLUME_LOOKBACK, VOLUME_THRESHOLD_1, VOLUME_THRESHOLD_2, VOLUME_THRESHOLD_EXTREME, VOLUME_TREND_COUNT
from config_connector import ENTRY_LOOKBACK, BIAS_LOOKBACK, SWING_WINDOW, COMPRESSION_LOOKBACK, ATR_PERIOD, BB_PERIOD, BB_STD, MIN_BODY_RATIO, EXPANSION_THRESHOLD, EPS

# =========================================================
# ================== 流动性触发 =========================
# =========================================================
def liquidity_event(high, low, open_, close):
    prev_high = max(high[-LOOKBACK-1:-1])
    prev_low = min(low[-LOOKBACK-1:-1])
    h = high[-1]
    l = low[-1]
    o = open_[-1]
    c = close[-1]
    sweep_high = h > prev_high * (1 + THRESHOLD)
    sweep_low = l < prev_low * (1 - THRESHOLD)
    fake_break_high = sweep_high and c < prev_high
    fake_break_low = sweep_low and c > prev_low
    body = max(abs(c - o), MIN_BODY)
    upper_wick = h - max(o, c)
    lower_wick = min(o, c) - l
    wick_ratio_up = upper_wick / body
    wick_ratio_down = lower_wick / body
    strong_rejection_high = fake_break_high and wick_ratio_up > WICK_RATIO_THRESHOLD
    strong_rejection_low = fake_break_low and wick_ratio_down > WICK_RATIO_THRESHOLD
    direction = None
    if strong_rejection_low:
        direction = "long"
    elif strong_rejection_high:
        direction = "short"
    elif sweep_low:
        direction = "long"
    elif sweep_high:
        direction = "short"
    score = 1
    if sweep_high or sweep_low:
        score += 3
    if fake_break_high or fake_break_low:
        score += 3
    if strong_rejection_high or strong_rejection_low:
        score += 2
    if wick_ratio_up > EXTREME_WICK_RATIO or wick_ratio_down > EXTREME_WICK_RATIO:
        score += 1
    score = min(score, 10)
    if score >= 8:
        subtype = "strong_rejection"
    elif score >= 6:
        subtype = "rejection"
    elif score >= 4:
        subtype = "sweep"
    else:
        subtype = "none"
    return {
        "score": score,
        "direction": direction,
        "type": "liquidity_event",
        "subtype": subtype,
        "meta": {
            "prev_high": prev_high,
            "prev_low": prev_low,
            "wick_ratio_up": round(wick_ratio_up, 3),
            "wick_ratio_down": round(wick_ratio_down, 3)
        }
    }

# =========================================================
# ================== 动量扩张 ===========================
# =========================================================
def momentum_expansion(high, low, open_, close):
    if len(high) < MOMENTUM_LOOKBACK + CONSECUTIVE_COUNT:
        return {"score":1,"direction":None,"type":"momentum_expansion","subtype":"invalid","meta":{}}
    total_range = sum(high[-MOMENTUM_LOOKBACK-1:-1] - low[-MOMENTUM_LOOKBACK-1:-1])
    avg_range = total_range / MOMENTUM_LOOKBACK
    current_range = high[-1] - low[-1]
    momentum_ratio = current_range / (avg_range + EPS)
    close_position = (close[-1] - low[-1]) / (current_range + EPS)
    strong_close_long = close_position > (1 - STRONG_CLOSE_RATIO)
    strong_close_short = close_position < STRONG_CLOSE_RATIO
    direction = None
    if strong_close_long:
        direction = "long"
    elif strong_close_short:
        direction = "short"

    def consecutive(direction_type):
        for i in range(-CONSECUTIVE_COUNT, 0):
            if direction_type == "bull" and close[i] <= open_[i]:
                return False
            if direction_type == "bear" and close[i] >= open_[i]:
                return False
        return True

    bull_seq = consecutive("bull")
    bear_seq = consecutive("bear")
    score = 1
    if momentum_ratio > MOMENTUM_THRESHOLD_1:
        score += 3
    if momentum_ratio > MOMENTUM_THRESHOLD_2:
        score += 2
    if strong_close_long or strong_close_short:
        score += 2
    if bull_seq or bear_seq:
        score += 1
    if momentum_ratio > MOMENTUM_THRESHOLD_EXTREME:
        score += 1
    score = min(score, 10)
    if score >= 9:
        subtype="explosive"
    elif score >= 7:
        subtype="strong"
    else:
        subtype="weak"
    return {
        "score": score,
        "direction": direction,
        "type": "momentum_expansion",
        "subtype": subtype,
        "meta": {
            "momentum_ratio": round(momentum_ratio,3),
            "avg_range": round(avg_range,3),
            "current_range": round(current_range,3),
            "close_position": round(close_position,3),
            "bull_seq": bull_seq,
            "bear_seq": bear_seq
        }
    }

# =========================================================
# ================== 成交量参与 =========================
# =========================================================
def volume_participation(volume, close):
    if len(volume) < VOLUME_LOOKBACK + 2:
        return {"score":1,"direction":None,"type":"volume_participation","subtype":"invalid","meta":{}}
    avg_volume = sum(volume[-VOLUME_LOOKBACK-1:-1])/VOLUME_LOOKBACK
    current_volume = volume[-1]
    volume_ratio = current_volume / (avg_volume + EPS)
    price_up = close[-1] > close[-2]
    price_down = close[-1] < close[-2]
    volume_up = volume[-1] > volume[-2]
    confirm_long = price_up and volume_up
    confirm_short = price_down and volume_up
    direction = None
    if confirm_long:
        direction="long"
    elif confirm_short:
        direction="short"

    def volume_trend():
        for i in range(-VOLUME_TREND_COUNT,0):
            if volume[i]<=volume[i-1]:
                return False
        return True
    sustained = volume_trend()
    divergence = (price_up and not volume_up) or (price_down and not volume_up)
    score = 1
    if volume_ratio > VOLUME_THRESHOLD_1:
        score +=3
    if volume_ratio > VOLUME_THRESHOLD_2:
        score +=2
    if confirm_long or confirm_short:
        score +=2
    if sustained:
        score +=1
    if volume_ratio > VOLUME_THRESHOLD_EXTREME:
        score +=1
    if divergence:
        score -=1
    score = max(1,min(score,10))
    if score >= 9:
        subtype="explosive_volume"
    elif score >= 7:
        subtype="confirmed_volume"
    elif score >= 5:
        subtype="neutral_volume"
    else:
        subtype="weak_volume"
    return {
        "score": score,
        "direction": direction,
        "type":"volume_participation",
        "subtype":subtype,
        "meta":{
            "volume_ratio": round(volume_ratio,3),
            "sustained": sustained,
            "divergence": divergence
        }
    }

# =========================================================
# ================== 信号引擎 ===========================
# =========================================================
def signal_engine(high, low, open_, close, volume):
    """统一五角雷达计算接口"""
    liquidity = liquidity_event(high, low, open_, close)
    momentum = momentum_expansion(high, low, open_, close)
    vol_part = volume_participation(volume, close)
    # momentum方向作为结构参考
    direction = momentum["direction"]
    from structure_module import structure_alignment_v2
    from compression_module import compression_expansion_module
    structure = structure_alignment_v2(high, low, close, direction)
    compression = compression_expansion_module(open_, high, low, close)

    radar = {
        "liquidity_event": liquidity,
        "momentum_expansion": momentum,
        "volume_participation": vol_part,
        "structure_alignment": structure,
        "compression_expansion": compression
    }
    return radar

