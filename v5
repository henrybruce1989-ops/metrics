# =========================================================
# ================== Binance 连接器 =======================
# =========================================================
class BinanceConnector:
    """管理 REST 与 WebSocket 连接，支持断线重连"""
    def __init__(self, api_key, api_secret, testnet=False):
        self.api_key = api_key
        self.api_secret = api_secret
        self.testnet = testnet
        self.client = Client(api_key, api_secret, testnet=testnet)
        self.ws_url = "wss://fstream.binance.com/ws" if not testnet else "wss://stream.binancefuture.com/ws"
        self.subscribed_symbols = set()
        self.ws = None
        self.running = False
        self.msg_queue = []

    def start_ws(self, symbols, kline_interval='1m'):
        """启动WebSocket线程监听K线"""
        self.subscribed_symbols = set(symbols)
        self.kline_interval = kline_interval
        self.running = True
        self.ws_thread = Thread(target=self._run_ws, daemon=True)
        self.ws_thread.start()
        logging.info(f"WebSocket启动: {len(symbols)} 个交易对订阅")

    def _on_message(self, ws, message):
        try:
            msg = json.loads(message)
            if 'k' in msg:
                k = msg['k']
                self.msg_queue.append(k)
        except Exception as e:
            logging.warning(f"消息解析失败: {e}")

    def _on_error(self, ws, error):
        logging.error(f"WebSocket异常: {error}")

    def _on_close(self, ws, close_status_code, close_msg):
        logging.warning(f"WebSocket关闭, code={close_status_code}, msg={close_msg}")
        if self.running:
            logging.info("尝试重新连接 WebSocket...")
            time.sleep(3)
            self._run_ws()

    def _on_open(self, ws):
        logging.info("WebSocket连接成功")
        params = [f"{symbol.lower()}@kline_{self.kline_interval}" for symbol in self.subscribed_symbols]
        sub_msg = {
            "method": "SUBSCRIBE",
            "params": params,
            "id": int(time.time())
        }
        ws.send(json.dumps(sub_msg))

    def _run_ws(self):
        ws_url = self.ws_url
        self.ws = websocket.WebSocketApp(
            ws_url,
            on_open=self._on_open,
            on_message=self._on_message,
            on_close=self._on_close,
            on_error=self._on_error
        )
        self.ws.run_forever()

    def stop_ws(self):
        self.running = False
        if self.ws:
            self.ws.close()
            logging.info("WebSocket已关闭")

    def get_latest_msg(self):
        if self.msg_queue:
            return self.msg_queue.pop(0)
        return None

