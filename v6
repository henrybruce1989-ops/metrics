class KlineCache:
    """
    保存每个币对的K线数据，保证只保留最新 KLINE_CACHE_LENGTH 条
    """
    def __init__(self):
        self.data = {}

    def update(self, symbol, kline):
        if symbol not in self.data:
            self.data[symbol] = deque(maxlen=KLINE_CACHE_LENGTH)
        self.data[symbol].append(kline)

    def get(self, symbol, field):
        if symbol not in self.data:
            return []
        return [k[field] for k in self.data[symbol]]

kline_cache = KlineCache()

