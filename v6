# ================== Binance API Wrapper =================
# =========================================================
class BinanceHandler:
    def __init__(self, api_key, api_secret):
        self.client = Client(api_key, api_secret)
        self.ws_threads = {}
        self.kline_cache = KlineCache()

    def get_active_symbols(self, min_volume=15000000):
        tickers = self.client.futures_ticker()
        active = []
        for t in tickers:
            if float(t['quoteVolume']) >= min_volume:
                active.append(t['symbol'])
        return active

    def start_kline_ws(self, symbol, interval='1m'):
        if symbol in self.ws_threads:
            return
        def run_ws():
            while True:
                try:
                    klines = self.client.futures_klines(symbol=symbol, interval=interval, limit=100)
                    o = [float(k[1]) for k in klines]
                    h = [float(k[2]) for k in klines]
                    l = [float(k[3]) for k in klines]
                    c = [float(k[4]) for k in klines]
                    v = [float(k[5]) for k in klines]
                    self.kline_cache.add(symbol, {"open":o[-1], "high":h[-1], "low":l[-1], "close":c[-1], "volume":v[-1]})
                    time.sleep(10)
                except Exception as e:
                    print(f"[WebSocket重连] {symbol} 异常: {e}")
                    time.sleep(5)
        t = threading.Thread(target=run_ws, daemon=True)
        t.start()
        self.ws_threads[symbol] = t

# =========================================================
# ================== Main Real-time Loop =================
# =========================================================
def run_real_time(api_key, api_secret):
    binance = BinanceHandler(api_key, api_secret)
    symbols = binance.get_active_symbols(min_volume=15000000)

    for s in symbols:
        binance.start_kline_ws(s, interval='1m')

    while True:
        for s in symbols:
            klist = binance.kline_cache.get(s)
            if len(klist) < LOOKBACK:
                continue
            open_ = [k['open'] for k in klist]
            high = [k['high'] for k in klist]
            low = [k['low'] for k in klist]
            close = [k['close'] for k in klist]
            volume = [k['volume'] for k in klist]

            # 方向判断可由结构模块或其他自定义逻辑
            direction = None
            struct = structure_alignment_v2(high, low, close, direction)
            if struct["score"]>5:
                direction = struct["meta"]["entry_trend"]

            signals = five_radar(open_, high, low, close, volume, direction)
            save_signal_csv(s, signals)
            if signals["avg_score"] >= SIGNAL_PUSH_THRESHOLD:
                send_serverchan(f"{s} | Score:{signals['avg_score']:.2f} | Dir:{signals['overall_direction']}")
        time.sleep(15)      
