def symbol_manager_loop(interval=60):
    """
    定期刷新满足24H成交额阈值的币对，并更新WebSocket订阅
    """
    global ws_manager
    while True:
        try:
            active_symbols = get_active_symbols()
            with ws_manager.lock:
                old_symbols = set(ws_manager.symbols)
                new_symbols = set(active_symbols)
                if new_symbols != old_symbols:
                    print(f"[币对更新] 旧: {len(old_symbols)} 个，新: {len(new_symbols)} 个")
                    ws_manager.update_symbols(active_symbols)
        except Exception as e:
            print(f"[币对管理异常] {e}")
        time.sleep(interval)

# =========================================================
# ================== 自动重连线程 ========================
# =========================================================
def reconnect_loop(check_interval=10):
    """
    自动检测WebSocket是否运行，失败时重连
    """
    global ws_manager
    while True:
        try:
            if not ws_manager.running:
                print("[重连WebSocket] 检测到连接停止，尝试重连")
                ws_manager.start()
        except Exception as e:
            print(f"[WebSocket重连异常] {e}")
        time.sleep(check_interval)

