def init_ws():
    """
    初始化WebSocket管理器并启动
    """
    global ws_manager
    active_symbols = get_active_symbols()
    ws_manager = BinanceWS(active_symbols)
    ws_manager.start()

    # 启动币对动态管理线程
    threading.Thread(target=symbol_manager_loop, daemon=True).start()
    # 启动自动重连线程
    threading.Thread(target=reconnect_loop, daemon=True).start()  

