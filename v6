def fetch_klines(symbol, interval="1m", limit=KLINE_CACHE_LENGTH):
    """
    获取历史K线并缓存
    """
    try:
        klines = client.get_klines(symbol=symbol, interval=interval, limit=limit)
        for k in klines:
            kline_cache.update(symbol, {
                "open": float(k[1]),
                "high": float(k[2]),
                "low": float(k[3]),
                "close": float(k[4]),
                "volume": float(k[5]),
                "timestamp": k[0]
            })
    except BinanceRequestException as e:
        print(f"[请求异常] {symbol} {e}")
    except Exception as e:
        print(f"[K线获取异常] {symbol} {e}")

# =========================================================
# ================== WebSocket 实时订阅 ==================
# =========================================================
class BinanceWS:
    """
    管理Binance WebSocket连接，支持自动重连和K线实时缓存
    """
    def __init__(self, symbols, interval="1m"):
        self.symbols = symbols
        self.interval = interval
        self.twm = ThreadedWebsocketManager(api_key=API_KEY, api_secret=API_SECRET)
        self.running = False
        self.lock = threading.Lock()

    def start(self):
        """
        启动WebSocket
        """
        self.running = True
        self.twm.start()
        self._subscribe_all()

    def stop(self):
        """
        停止WebSocket
        """
        self.running = False
        self.twm.stop()

    def _subscribe_all(self):
        """
        订阅所有币对的K线
        """
        for symbol in self.symbols:
            self.twm.start_kline_socket(callback=self._kline_callback, symbol=symbol, interval=self.interval)

    def _kline_callback(self, msg):
        """
        K线回调
        """
        if msg['e'] != 'kline':
            return
        k = msg['k']
        kline_cache.update(k['s'], {
            "open": float(k['o']),
            "high": float(k['h']),
            "low": float(k['l']),
            "close": float(k['c']),
            "volume": float(k['v']),
            "timestamp": k['t']
        })

    def update_symbols(self, new_symbols):
        """
        动态更新订阅币对
        """
        with self.lock:
            # 停止旧订阅
            self.stop()
            self.symbols = new_symbols
            # 重启订阅
            self.twm = ThreadedWebsocketManager(api_key=API_KEY, api_secret=API_SECRET)
            self.start()

