# 1. 流动性触发
def liquidity_event(high, low, open_, close):
    prev_high = max(high[-LOOKBACK-1:-1])
    prev_low  = min(low[-LOOKBACK-1:-1])

    h = high[-1]
    l = low[-1]
    o = open_[-1]
    c = close[-1]

    sweep_high = h > prev_high * (1 + THRESHOLD)
    sweep_low  = l < prev_low  * (1 - THRESHOLD)

    fake_break_high = sweep_high and c < prev_high
    fake_break_low  = sweep_low  and c > prev_low

    body = max(abs(c - o), MIN_BODY)
    upper_wick = h - max(o, c)
    lower_wick = min(o, c) - l
    wick_ratio_up = upper_wick / body
    wick_ratio_down = lower_wick / body

    strong_rejection_high = fake_break_high and wick_ratio_up > WICK_RATIO_THRESHOLD
    strong_rejection_low  = fake_break_low  and wick_ratio_down > WICK_RATIO_THRESHOLD

    direction = None
    if strong_rejection_low:
        direction = "long"
    elif strong_rejection_high:
        direction = "short"
    elif sweep_low:
        direction = "long"
    elif sweep_high:
        direction = "short"

    score = 1
    if sweep_high or sweep_low:
        score += 3
    if fake_break_high or fake_break_low:
        score += 3
    if strong_rejection_high or strong_rejection_low:
        score += 2
    if wick_ratio_up > EXTREME_WICK_RATIO or wick_ratio_down > EXTREME_WICK_RATIO:
        score += 1
    score = min(score, 10)

    if score >= 8:
        subtype = "strong_rejection"
    elif score >= 6:
        subtype = "rejection"
    elif score >= 4:
        subtype = "sweep"
    else:
        subtype = "none"

    return {
        "score": score,
        "direction": direction,
        "type": "liquidity_event",
        "subtype": subtype,
        "meta": {
            "prev_high": prev_high,
            "prev_low": prev_low,
            "wick_ratio_up": wick_ratio_up,
            "wick_ratio_down": wick_ratio_down
        }
    }
              
# =========================================================
# ================== Momentum Expansion ==================
# =========================================================
def momentum_expansion(high, low, open_, close):
    if len(high) < MOMENTUM_LOOKBACK + CONSECUTIVE_COUNT:
        return {"score":1,"direction":None,"type":"momentum_expansion","subtype":"invalid","meta":{}}

    total_range = sum(high[-MOMENTUM_LOOKBACK-1:-1] - low[-MOMENTUM_LOOKBACK-1:-1])
    avg_range = total_range / MOMENTUM_LOOKBACK
    current_range = high[-1] - low[-1]
    momentum_ratio = current_range / (avg_range + EPS)

    close_position = (close[-1] - low[-1]) / (current_range + EPS)
    strong_close_long = close_position > (1 - STRONG_CLOSE_RATIO)
    strong_close_short = close_position < STRONG_CLOSE_RATIO

    direction = None
    if strong_close_long:
        direction = "long"
    elif strong_close_short:
        direction = "short"

    def consecutive(direction_type):
        for i in range(-CONSECUTIVE_COUNT, 0):
            if direction_type == "bull" and close[i] <= open_[i]:
                return False
            if direction_type == "bear" and close[i] >= open_[i]:
                return False
        return True

    bull_seq = consecutive("bull")
    bear_seq = consecutive("bear")

    score = 1
    if momentum_ratio > MOMENTUM_THRESHOLD_1: score += 3
    if momentum_ratio > MOMENTUM_THRESHOLD_2: score += 2
    if strong_close_long or strong_close_short: score += 2
    if bull_seq or bear_seq: score += 1
    if momentum_ratio > MOMENTUM_THRESHOLD_EXTREME: score += 1
    score = min(score, 10)

    if score >= 9: subtype="explosive"
    elif score >= 7: subtype="strong"
    else: subtype="weak"

    return {
        "score": score,
        "direction": direction,
        "type": "momentum_expansion",
        "subtype": subtype,
        "meta": {
            "momentum_ratio": momentum_ratio,
            "avg_range": avg_range,
            "current_range": current_range,
            "close_position": close_position,
            "bull_seq": bull_seq,
            "bear_seq": bear_seq
        }
    }

# =========================================================
# ================== Volume Participation ================
# =========================================================
def volume_participation(volume, close):
    if len(volume) < VOLUME_LOOKBACK + 2:
        return {"score":1,"direction":None,"type":"volume_participation","subtype":"invalid","meta":{}}

    avg_volume = sum(volume[-VOLUME_LOOKBACK-1:-1])/VOLUME_LOOKBACK
    current_volume = volume[-1]
    volume_ratio = current_volume / (avg_volume + EPS)

    price_up = close[-1] > close[-2]
    price_down = close[-1] < close[-2]
    volume_up = volume[-1] > volume[-2]

    confirm_long = price_up and volume_up
    confirm_short = price_down and volume_up

    direction = None
    if confirm_long: direction="long"
    elif confirm_short: direction="short"

    def volume_trend():
        for i in range(-VOLUME_TREND_COUNT, 0):
            if volume[i] <= volume[i-1]: return False
        return True

    sustained = volume_trend()
    divergence = (price_up and not volume_up) or (price_down and not volume_up)

    score = 1
    if volume_ratio > VOLUME_THRESHOLD_1: score += 3
    if volume_ratio > VOLUME_THRESHOLD_2: score += 2
    if confirm_long or confirm_short: score += 2
    if sustained: score += 1
    if volume_ratio > VOLUME_THRESHOLD_EXTREME: score += 1
    if divergence: score -= 1
    score = max(1, min(score, 10))

    if score >= 9: subtype="explosive_volume"
    elif score >= 7: subtype="confirmed_volume"
    elif score >= 5: subtype="neutral_volume"
    else: subtype="weak_volume"

    return {
        "score": score,
        "direction": direction,
        "type": "volume_participation",
        "subtype": subtype,
        "meta": {
            "volume_ratio": volume_ratio,
            "avg_volume": avg_volume,
            "current_volume": current_volume,
            "sustained": sustained,
            "divergence": divergence
        }
    }

# =========================================================
# ================== Structure Alignment =================
# =========================================================
def structure_alignment_v2(high, low, close, direction):
    if len(close) < BIAS_LOOKBACK + SWING_WINDOW*2:
        return {"score":1,"type":"structure_alignment","subtype":"invalid","meta":{}}

    def detect_structure(high, low, close, lookback):
        h = high[-lookback:]
        l = low[-lookback:]
        c = close[-lookback:]

        swing_highs=[]
        swing_lows=[]
        for i in range(SWING_WINDOW, len(h)-SWING_WINDOW):
            if all(h[i]>h[i-j] and h[i]>h[i+j] for j in range(1,SWING_WINDOW+1)): swing_highs.append((i,h[i]))
            if all(l[i]<l[i-j] and l[i]<l[i+j] for j in range(1,SWING_WINDOW+1)): swing_lows.append((i,l[i]))

        hh = hl = lh = ll = 0
        for i in range(1,len(swing_highs)):
            if swing_highs[i][1] > swing_highs[i-1][1]: hh+=1
            else: lh+=1
        for i in range(1,len(swing_lows)):
            if swing_lows[i][1] > swing_lows[i-1][1]: hl+=1
            else: ll+=1

        total = hh+hl+lh+ll+EPS
        bullish_score = (hh+hl)/total
        bearish_score = (lh+ll)/total

        if bullish_score>0.6: trend="long"; strength=bullish_score
        elif bearish_score>0.6: trend="short"; strength=bearish_score
        else: trend="range"; strength=max(bullish_score,bearish_score)

        last_high = swing_highs[-1][1] if swing_highs else None
        last_low = swing_lows[-1][1] if swing_lows else None

        position="inside"
        if last_high and c[-1]>last_high: position="break_up"
        elif last_low and c[-1]<last_low: position="break_down"

        return trend, strength, position, last_high, last_low

    entry_trend, entry_strength, position, last_high, last_low = detect_structure(high, low, close, ENTRY_LOOKBACK)
    bias_trend, bias_strength, _, _, _ = detect_structure(high, low, close, BIAS_LOOKBACK)

    score = 1
    weak_signal=False
    if direction==entry_trend: score+=4
    else: weak_signal=True
    if direction==bias_trend: score+=2
    if direction==entry_trend and direction==bias_trend: score+=2
    if position=="break_up" and direction=="long": score+=2
    if position=="break_down" and direction=="short": score+=2
    score = max(1, min(score,10))

    if weak_signal: subtype="weak_counter_trend"
    elif score>=8: subtype="strong_trend_aligned"
    elif score>=5: subtype="trend_aligned"
    else: subtype="neutral_structure"

    return {
        "score":score,
        "type":"structure_alignment",
        "subtype":subtype,
        "meta":{
            "entry_trend":entry_trend,
            "bias_trend":bias_trend,
            "entry_strength":entry_strength,
            "bias_strength":bias_strength,
            "position":position,
            "weak_signal":weak_signal,
            "last_high":last_high,
            "last_low":last_low
        }
    }  

