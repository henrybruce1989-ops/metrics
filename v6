# ================== K-line Cache ========================
# =========================================================
class KlineCache:
    def __init__(self, maxlen=500):
        self.cache = {}
        self.maxlen = maxlen

    def add(self, symbol, kline):
        if symbol not in self.cache:
            self.cache[symbol] = deque(maxlen=self.maxlen)
        self.cache[symbol].append(kline)

    def get(self, symbol):
        return list(self.cache.get(symbol, []))

