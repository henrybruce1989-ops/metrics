# ================== WebSocket 管理 ======================
# =========================================================
class BinanceWS:
    def __init__(self, symbols, interval="1m"):
        self.symbols = symbols
        self.interval = interval
        self.twm = ThreadedWebsocketManager(api_key=API_KEY, api_secret=API_SECRET)
        self.running = False
        self.lock = threading.Lock()

    def start(self):
        self.running = True
        self.twm.start()
        self._subscribe_all()

    def stop(self):
        self.running = False
        try:
            self.twm.stop()
        except:
            pass

    def _subscribe_all(self):
        for s in self.symbols:
            self.twm.start_kline_socket(
                callback=self._kline_callback,
                symbol=s,
                interval=self.interval
            )

    def _kline_callback(self, msg):
        global last_kline_time  # <--- 新增这一行
        global last_kline_time  # <--- 新增这一行

        if msg['e'] != 'kline':
            return

        k = msg['k']

        # ✅ 只处理收盘K线（关键修复）
        if not k['x']:
            return

        kline_cache.update(k['s'], {
            "open": float(k['o']),
            "high": float(k['h']),
            "low": float(k['l']),
            "close": float(k['c']),
            "volume": float(k['v']),
            "timestamp": k['t']
        })

    def update_symbols(self, new_symbols):
        with self.lock:
            self.stop()
            self.symbols = new_symbols
            self.twm = ThreadedWebsocketManager(api_key=API_KEY, api_secret=API_SECRET)
            self.start()

