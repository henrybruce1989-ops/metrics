# ================== 推送模块（Server酱） ==================
# =========================================================
def format_push(signal):
    return f"""
【交易信号】
币种: {signal['symbol']}
方向: {signal['direction']}
评分: {signal['avg_score']:.2f}

—— 五角雷达 ——
流动性: {signal['liquidity']['score']} ({signal['liquidity']['subtype']})
动量: {signal['momentum']['score']} ({signal['momentum']['subtype']})
成交量: {signal['volume']['score']} ({signal['volume']['subtype']})
结构: {signal['structure']['score']} ({signal['structure']['subtype']})
压缩: {signal['compression']['score']}

—— META ——
流动性: {signal['liquidity']['meta']}
动量: {signal['momentum']['meta']}
成交量: {signal['volume']['meta']}
结构: {signal['structure']['meta']}
压缩: {signal['compression']['meta']}
"""

# =========================================================
# ================== 信号触发核心 =========================
# =========================================================
def process_symbol(symbol):
    klines = kline_cache.get_all(symbol)
    if len(klines) < 100:
        return

    last_k = klines[-1]
    k_ts = last_k["timestamp"]

    # ✅ 去重
    if not signal_filter.is_new_signal(symbol, k_ts):
        return

    signal = calculate_five_radar(klines)
    if not signal:
        return

    signal["symbol"] = symbol
    signal["timestamp"] = k_ts

    # ✅ 信号过滤（核心，不再乱推）
    if signal["avg_score"] < SIGNAL_PUSH_THRESHOLD:
        return

    # 至少两个模块同方向
    dirs = [
        signal["liquidity"]["direction"],
        signal["momentum"]["direction"],
        signal["volume"]["direction"]
    ]

    if dirs.count("long") < 2 and dirs.count("short") < 2:
        return

    # ================== 推送 ==================
    text = format_push(signal)
    send_serverchan(text)

    # ================== CSV ==================
    save_full_csv(signal)

    print(f"[信号] {symbol} | {signal['direction']} | {signal['avg_score']}")


# =========================================================
# ================== 主循环（非阻塞） =====================
# =========================================================
def main_loop():
    while True:
        try:
            symbols = list(kline_cache.data.keys())

            for symbol in symbols:
                process_symbol(symbol)

        except Exception as e:
            print(f"[主循环异常] {e}")

        time.sleep(1)


# =========================================================
# ================== 主程序入口 ===========================
# =========================================================
if __name__ == "__main__":
    print("🚀 系统启动")

    # 初始化WS
    init_ws()

    # 启动主循环
    main_loop()      
  
