ws_manager = None

def symbol_manager_loop():
    global ws_manager
    while True:
        try:
            new_symbols = get_active_symbols()
            if set(new_symbols) != set(ws_manager.symbols):
                print(f"[币对更新] {len(new_symbols)} 个")
                ws_manager.update_symbols(new_symbols)
        except Exception as e:
            print(f"[币对管理异常] {e}")
        time.sleep(60)

def reconnect_loop():
    global ws_manager, last_kline_time

    while True:
        try:
            # 原有逻辑：WS未启动
            if not ws_manager.running:
                print("[WS重连: 未运行]")
                ws_manager.start()

            # ✅ 新增：断流检测（核心）
            if time.time() - last_kline_time > 30:
                print("[WS断流检测 → 重启WS]")
                ws_manager.update_symbols(ws_manager.symbols)

        except Exception as e:
            print(f"[重连异常] {e}")

        time.sleep(10)

def init_ws():
    global ws_manager
    symbols = get_active_symbols()
    print(f"[初始化WS] 币对数量: {len(symbols)}")

    ws_manager = BinanceWS(symbols)
    ws_manager.start()

    threading.Thread(target=symbol_manager_loop, daemon=True).start()
    threading.Thread(target=reconnect_loop, daemon=True).start()
              
