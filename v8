# ⚠️ 作用：把 kline_cache 的 dict 数据 → 转换为数组输入
# ⚠️ 不改变任何指标逻辑，只做输入适配

def extract_ohlcv_arrays(klines):
    open_ = np.array([k["open"] for k in klines])
    high = np.array([k["high"] for k in klines])
    low = np.array([k["low"] for k in klines])
    close = np.array([k["close"] for k in klines])
    volume = np.array([k["volume"] for k in klines])
    return open_, high, low, close, volume


# =========================================================
# ================== 五角雷达总调度（核心入口） ============
# =========================================================
# ⚠️ 这是唯一新增函数（不改你任何模块逻辑）
# ⚠️ 只是把五个模块串起来

def calculate_five_radar(klines):
    if len(klines) < 100:
        return None

    open_, high, low, close, volume = extract_ohlcv_arrays(klines)

    # ================== 1. 流动性 ==================
    liquidity = liquidity_event(high, low, open_, close)

    # ================== 2. 动量 ====================
    momentum = momentum_expansion(high, low, open_, close)

    # ================== 3. 成交量 ==================
    volume_sig = volume_participation(volume, close)

    # ================== 4. 结构 ====================
    structure = structure_alignment_v2(
        high, low, close,
        liquidity.get("direction") or momentum.get("direction")
    )

    # ================== 5. 压缩扩张 ================
    compression = compression_expansion_module(open_, high, low, close)

    # ================== 汇总评分 ===================
    scores = [
        liquidity["score"],
        momentum["score"],
        volume_sig["score"],
        structure["score"],
        compression["score"]
    ]

    avg_score = float(np.mean(scores))

    # ================== 方向统一 ===================
    directions = [
        liquidity.get("direction"),
        momentum.get("direction"),
        volume_sig.get("direction")
    ]

    long_count = directions.count("long")
    short_count = directions.count("short")

    final_direction = None
    if long_count > short_count:
        final_direction = "long"
    elif short_count > long_count:
        final_direction = "short"

    # ================== 返回完整结构 ===================
    return {
        "symbol": None,  # 第三部分填充
        "timestamp": int(time.time() * 1000),

        "avg_score": avg_score,
        "direction": final_direction,

        "liquidity": liquidity,
        "momentum": momentum,
        "volume": volume_sig,
        "structure": structure,
        "compression": compression
    }

